# BitGN Platform
BITGN_HOST=https://api.bitgn.com
BITGN_API_KEY=

# OpenAI or OpenAI-compatible provider
OPENAI_CREDENTIAL_TARGET=pac1-py-openai
# Fallbacks if Windows Credential Manager is not available:
OPENAI_API_KEY=
OPENAI_ACCESS_TOKEN=
OPENAI_BASE_URL=
# OPENAI_BASE_URL=http://localhost:11434/v1

# Benchmark settings
BENCH_ID=bitgn/pac1-dev
MODEL_ID=gpt-5
OPENAI_REASONING_EFFORT=medium
PAC1_MAX_WORKERS=4
PAC1_TASK_DELAY_SEC=5
PAC1_LOG_FILE=

# Optional extra guidance for the agent
# HINT=
